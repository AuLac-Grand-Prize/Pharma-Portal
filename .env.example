NODE_ENV=development
NEXT_PUBLIC_APP_NAME=PharmLink AI Portal
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Gateway (server-side only)
API_GATEWAY_URL=http://localhost:8080
API_GATEWAY_TIMEOUT_MS=15000

# API Gateway base URL for client-triggered calls (typed api layer, lib/api.ts).
# Public on purpose; keep the server-only API_GATEWAY_URL out of the client bundle.
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8080

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-strong-random-secret

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=

# Feature flags
NEXT_PUBLIC_FEATURE_RX_OCR=true
NEXT_PUBLIC_FEATURE_PHARMAGPT_CHAT=true
# When "true", the VietDrug engine page calls the real Gateway via lib/api.ts
# instead of rendering static mock alerts. Defaults OFF.
NEXT_PUBLIC_FEATURE_VIETDRUG_LIVE=false
